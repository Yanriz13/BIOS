{{-- SCRIPT --}}
{{-- ========================================= --}}
<script>

let currentTaskId = null;

let selectedImages = [];

let cameraStream = null;

const users = {

    elsa: {
        name: 'Elsa',
        role: 'Frontend Dev',
        avatar: 'https://i.pravatar.cc/40?img=1'
    },

    rizki: {
        name: 'Rizki',
        role: 'Backend Dev',
        avatar: 'https://i.pravatar.cc/40?img=5'
    }

};

function openUserModal(taskId)
{
    currentTaskId = taskId;

    const modal =
        document.getElementById('userModal');

    modal.classList.remove('hidden');

    modal.classList.add('flex');
}

function closeUserModal()
{
    const modal =
        document.getElementById('userModal');

    modal.classList.add('hidden');

    modal.classList.remove('flex');
}

function selectUser(userKey)
{
    const user = users[userKey];

    document.getElementById(`avatar-${currentTaskId}`).src =
        user.avatar;

    document.getElementById(`name-${currentTaskId}`).innerText =
        user.name;

    document.getElementById(`role-${currentTaskId}`).innerText =
        user.role;

    closeUserModal();
}

function allowDrop(ev)
{
    ev.preventDefault();
}

function drag(ev)
{
    const taskCard = ev.target.closest('.task-card');

    if (taskCard) {

        ev.dataTransfer.setData("text", taskCard.id);

    }
}

function drop(ev)
{
    ev.preventDefault();

    const data =
        ev.dataTransfer.getData("text");

    const task =
        document.getElementById(data);

    const dropZone =
        ev.target.closest('[ondrop]');

    if (dropZone && task) {

        dropZone.appendChild(task);

    }
}

function openChatModal(taskTitle)
{
    document.getElementById('chatTaskTitle').innerText =
        taskTitle + ' Chat';

    const modal =
        document.getElementById('chatModal');

    modal.classList.remove('hidden');

    modal.classList.add('flex');
}

function closeChatModal()
{
    const modal =
        document.getElementById('chatModal');

    modal.classList.add('hidden');

    modal.classList.remove('flex');

    closeCamera();

    removePreviewImage();
}

function sendMessage()
{
    const input =
        document.getElementById('chatInput');

    const chatBody =
        document.getElementById('chatBody');

    if (
        input.value.trim() === '' &&
        selectedImages.length === 0
    ) {
        return;
    }

    let imageHTML = '';

    if (selectedImages.length > 0) {

        imageHTML =
        `
            <div class="grid grid-cols-2 gap-2 mt-3 max-w-[260px]">
                ${
                    selectedImages.map(image => `
                        <img
                            src="${image}"
                            class="
                                w-full
                                h-32
                                object-cover
                                rounded-2xl
                                border
                                border-white/20
                                shadow-lg
                            "
                        >
                    `).join('')
                }
            </div>
        `;
    }

    const message =
    `
        <div class="flex justify-end">

            <div
                class="
                    bg-indigo-600
                    text-white
                    rounded-3xl
                    rounded-br-sm
                    px-4
                    py-3
                    shadow-sm
                    max-w-[320px]
                    overflow-hidden
                "
            >

                ${
                    input.value.trim() !== ''
                    ?
                    `
                        <p class="text-sm break-words">
                            ${input.value}
                        </p>
                    `
                    :
                    ''
                }

                ${imageHTML}

            </div>

        </div>
    `;

    chatBody.innerHTML += message;

    input.value = '';

    removePreviewImage();

    chatBody.scrollTop =
        chatBody.scrollHeight;
}

function previewSelectedImage(event)
{
    const files =
        event.target.files;

    if (!files.length) {

        return;
    }

    selectedImages = [];

    const previewContainer =
        document.getElementById('previewContainer');

    const previewWrapper =
        document.getElementById('previewWrapper');

    previewWrapper.innerHTML = '';

    previewContainer.classList.remove('hidden');

    Array.from(files).forEach((file, index) => {

        const reader =
            new FileReader();

        reader.onload = function(e)
        {
            selectedImages.push(e.target.result);

            const imageItem =
            `
                <div class="relative shrink-0">

                    <img
                        src="${e.target.result}"
                        class="
                            w-32
                            h-32
                            rounded-3xl
                            object-cover
                            border
                            border-slate-200
                            shadow
                        "
                    >

                    <button
                        onclick="removeSingleImage(${index})"
                        class="
                            absolute
                            -top-2
                            -right-2
                            w-7
                            h-7
                            rounded-full
                            bg-red-500
                            hover:bg-red-600
                            text-white
                            text-xs
                            shadow-lg
                        "
                    >
                        ✕
                    </button>

                </div>
            `;

            previewWrapper.innerHTML += imageItem;
        }

        reader.readAsDataURL(file);

    });
}
function removePreviewImage()
{
    selectedImages = [];

    document.getElementById('previewWrapper')
        .innerHTML = '';

    document.getElementById('previewContainer')
        .classList.add('hidden');

    document.getElementById('imageInput').value = '';
}
function openAddTaskModal()
{
    document
        .getElementById('addTaskModal')
        .classList.remove('hidden');

    document
        .getElementById('addTaskModal')
        .classList.add('flex');
}

function closeAddTaskModal()
{
    document
        .getElementById('addTaskModal')
        .classList.add('hidden');

    document
        .getElementById('addTaskModal')
        .classList.remove('flex');
}
function removeSingleImage(index)
{
    selectedImages.splice(index, 1);

    const previewWrapper =
        document.getElementById('previewWrapper');

    previewWrapper.innerHTML = '';

    selectedImages.forEach((image, newIndex) => {

        previewWrapper.innerHTML +=
        `
            <div class="relative shrink-0">

                <img
                    src="${image}"
                    class="
                        w-32
                        h-32
                        rounded-3xl
                        object-cover
                        border
                        border-slate-200
                        shadow
                    "
                >

                <button
                    onclick="removeSingleImage(${newIndex})"
                    class="
                        absolute
                        -top-2
                        -right-2
                        w-7
                        h-7
                        rounded-full
                        bg-red-500
                        hover:bg-red-600
                        text-white
                        text-xs
                        shadow-lg
                    "
                >
                    ✕
                </button>

            </div>
        `;

    });

    if (selectedImages.length === 0) {

        document.getElementById('previewContainer')
            .classList.add('hidden');
    }
}

async function openCamera()
{
    try {

        cameraStream =
            await navigator.mediaDevices.getUserMedia({
                video: true
            });

        const video =
            document.getElementById('cameraVideo');

        video.srcObject =
            cameraStream;

        document.getElementById('cameraContainer')
            .classList.remove('hidden');

    }
    catch (error) {

        alert('Camera access denied.');

    }
}

function closeCamera()
{
    if (cameraStream) {

        cameraStream.getTracks().forEach(track => track.stop());

        cameraStream = null;
    }

    document.getElementById('cameraContainer')
        .classList.add('hidden');
}

function capturePhoto()
{
    const video =
        document.getElementById('cameraVideo');

    const canvas =
        document.createElement('canvas');

    canvas.width =
        video.videoWidth;

    canvas.height =
        video.videoHeight;

    const ctx =
        canvas.getContext('2d');

    ctx.drawImage(
        video,
        0,
        0,
        canvas.width,
        canvas.height
    );

    const imageData =
        canvas.toDataURL('image/png');

    selectedImages.push(imageData);

    const previewContainer =
        document.getElementById('previewContainer');

    const previewWrapper =
        document.getElementById('previewWrapper');

    previewContainer.classList.remove('hidden');

    previewWrapper.innerHTML +=
    `
        <div class="relative shrink-0">

            <img
                src="${imageData}"
                class="
                    w-32
                    h-32
                    rounded-3xl
                    object-cover
                    border
                    border-slate-200
                    shadow
                "
            >

            <button
                onclick="removeSingleImage(${selectedImages.length - 1})"
                class="
                    absolute
                    -top-2
                    -right-2
                    w-7
                    h-7
                    rounded-full
                    bg-red-500
                    hover:bg-red-600
                    text-white
                    text-xs
                    shadow-lg
                "
            >
                ✕
            </button>

        </div>
    `;

    closeCamera();
}

window.onclick = function(event)
{
    const userModal =
        document.getElementById('userModal');

    const chatModal =
        document.getElementById('chatModal');

    if (event.target === userModal) {

        closeUserModal();

    }

    if (event.target === chatModal) {

        closeChatModal();

    }
}

</script>
@endsection